// ─── Safari Studio — Prisma Schema ──────────────────────────────────────────
//
// Document-store pattern: the full editor state (sections, days, properties,
// pricing, theme, etc.) is stored as a single JSONB column.  Top-level fields
// are extracted for listing / filtering without parsing the blob.
//
// User rows are created on first save, keyed by the auth provider's user ID
// (Clerk clerkUserId).  No password or session data lives here.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposals Proposal[]

  orgMemberships      OrgMembership[]
  assignedRequests    Request[]       @relation("RequestAssignee")
  authoredNotes       RequestNote[]   @relation("RequestNoteAuthor")
  presence            Presence?
  activityEvents      ActivityEvent[]
  createdReservations Reservation[]
  assignedProposalReservations ProposalReservation[]
  proposalEvents      ProposalEvent[]
  aiSuggestions       AISuggestion[]

  @@index([clerkUserId])
}

// ─── Org membership — per-user per-org profile ─────────────────────────────
//
// One row per (user × organization). Carries the per-org role + the user's
// per-org profile (signature, photo, notification prefs). A person who
// belongs to multiple orgs has one row per org so their role / signature
// can differ across workspaces.
//
// Role mirrors Clerk's org-level roles but we store it here so server-side
// queries (team lists, analytics) don't have to fan out to Clerk's API.

model OrgMembership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  role              String  @default("member") // owner | admin | member
  profilePhotoUrl   String?
  signatureUrl      String?
  roleTitle         String? // free-text "Founder / Safari Specialist"
  whatsapp          String? // E.164-ish or display number; used in proposals
  notificationPrefs Json? // { newRequest: bool, requestAssigned: bool }
  /** Set once the member has completed the /onboarding intake form.
   *  Middleware reads this to decide whether to gate dashboard access
   *  for new members. Existing members are migrated as completed. */
  onboardedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ─── Organization ───────────────────────────────────────────────────────────
//
// One row per Clerk organization. Each organization is the tenant scope for
// Proposals, BrandDNA, and other per-workspace data. Organizations represent
// a travel business — tour operator, DMC, agent, camp, lodge, safari brand.
// Row is upserted on first authenticated request that carries an orgId.

model Organization {
  id         String  @id @default(cuid())
  clerkOrgId String  @unique
  name       String?
  slug       String?

  // Super-admin-controlled lifecycle. "active" = full access; "suspended" =
  // workspace is frozen until the admin reactivates (used in lieu of billing
  // until the Stripe integration lands). Suspended orgs can still authenticate
  // via Clerk but every protected route gates on this flag.
  status          String    @default("active") // "active" | "suspended"
  suspendedAt     DateTime?
  suspendedReason String?

  // Commercial lifecycle — orthogonal to the paid plan below.
  // "trial" default; "pilot" is a hand-picked zero-cost engagement with
  // tierExpiresAt; "paid" is what an operator becomes once they subscribe.
  tier          String    @default("trial") // "trial" | "pilot" | "paid"
  tierExpiresAt DateTime?
  tierNote      String?

  // ── Paid plan (what they're actually subscribed to) ────────────────
  // Set to "consultant" | "explorer" | "operator" when they subscribe
  // via Paystack. "none" until then. Distinct from `tier` above, which
  // tracks free-access state (trial / pilot / paid).
  plan String @default("none") // "none" | "consultant" | "explorer" | "operator"

  // ── Follow-up automation level ─────────────────────────────────────
  // Operator-selected "power level" for AI follow-ups. Drives the
  // dashboard's UI per deal:
  //   "assisted"      — drafts only, manual send (default)
  //   "smart_assist"  — recommendations + one-click send
  //   "auto"          — auto-send timer with safety guards
  // isPremium is plumbed for future gating; today canUseMode() in
  // src/lib/followUpMode.ts always returns true regardless. When we
  // wire payment, flipping the gate is one line.
  followUpMode String  @default("assisted") // "assisted" | "smart_assist" | "auto"
  isPremium    Boolean @default(false)

  // ── Payment processor linkage ──────────────────────────────────────
  // paymentProcessor identifies which rail the subscription runs on.
  // Paystack is the EA primary (card + M-Pesa for Kenya). Stripe
  // arrives later for international card coverage.
  paymentProcessor         String? // "paystack" | "stripe" | null
  paystackCustomerCode     String?
  paystackSubscriptionCode String?
  paystackEmailToken       String? // Required by Paystack for subscription actions
  currentPeriodEnd         DateTime?
  lastPaymentAt            DateTime?
  // Set by a user-initiated cancel; the subscription runs until
  // currentPeriodEnd and then does not renew. Paystack still charges
  // until we call their /subscription/disable API (done server-side on
  // cancel), so this flag is belt-and-braces.
  cancelAtPeriodEnd        Boolean   @default(false)

  // ── GoHighLevel integration (per-org credentials) ─────────────────
  // Each operator connects their own GHL workspace. Service layer reads
  // these on every call; if `ghlAccessToken` is null the integration is
  // a no-op and the legacy local-only behaviour is preserved.
  // TODO: encrypt-at-rest (pgsodium / column-level KMS) before GA.
  ghlAccessToken String?
  ghlLocationId  String?
  ghlPipelineId  String?
  // Map of internal-status → GHL pipeline-stage ID. Keys:
  //   "new" | "working" | "proposal_sent" | "booked" | "not_booked"
  ghlStageIds    Json?
  // Map of internal-event → GHL workflow ID. Keys:
  //   "proposal_sent" | "proposal_viewed" | "deposit_paid" | "reservation_followup"
  ghlWorkflowIds Json?

  // ── Intelligence — Phase 5 follow-up automation ───────────────────
  // When true, the priorities dashboard auto-creates open tasks for
  // HOT deals that don't already have one. Default off so existing
  // workspaces aren't surprised by inbox-full of auto-tasks on day one.
  autoCreateHotTasks Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposals        Proposal[]
  brandDNA         BrandDNAProfile?
  destinationMedia DestinationMediaAsset[]
  locations        Location[]
  properties       Property[]
  propertyTags     PropertyTag[]

  memberships     OrgMembership[]
  clients         Client[]
  requests        Request[]
  leadSources     LeadSource[]
  requestCounters RequestCounter[]
  presences       Presence[]
  activityEvents  ActivityEvent[]
  reservations         Reservation[]
  proposalReservations ProposalReservation[]
  messages             Message[]
  integrationLogs      IntegrationLog[]
  proposalEvents       ProposalEvent[]
  proposalActivitySummaries ProposalActivitySummary[]
  proposalCounters     ProposalCounter[]
  aiSuggestions        AISuggestion[]

  @@index([clerkOrgId])
}

// ─── Brand DNA ──────────────────────────────────────────────────────────────
//
// One profile per organization. Every field is optional — Brand DNA is a
// progressive enhancement, never a blocker. Completion is scored with
// weighted sections (see src/lib/brandDNA.ts) to surface a single % and a
// "next best action" recommendation.
//
// Voice sliders are stored as 0–100 ints where null means "not yet set".

model BrandDNAProfile {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Brand Core
  brandName        String?
  logoUrl          String?
  websiteUrl       String?
  tagline          String?
  shortDescription String?

  // Voice & Tone — 0 is the left label, 100 is the right label
  voiceFormality    Int? //   0 formal          ↔ 100 conversational
  voiceLuxury       Int? //   0 luxury          ↔ 100 adventurous
  voiceDensity      Int? //   0 concise         ↔ 100 detailed
  voiceStorytelling Int? //   0 storytelling    ↔ 100 informational
  writingSample1    String?
  writingSample2    String?

  // Visual Style
  brandColors          Json? // [{ hex: string, role?: string }]
  headingFont          String?
  bodyFont             String?
  customFontUrl        String?
  preferredImageStyles String[] // e.g. "wildlife_closeup", "landscape", "lodge_interior", "guest_experience", "beach", "cultural"
  imageLibrary         Json? // [{ url: string, caption?: string, tags?: string[] }]
  // Per-section style overrides — keyed by SectionType. Each value
  // is a partial StyleOverrides record (sectionSurface, cardBg,
  // accent, headingText, dayHeadBg, displayFont, bodyFont, etc.).
  // Applied at proposal-clone time; per-proposal SectionChrome
  // edits still win.
  sectionStyles        Json? // Record<SectionType, Partial<StyleOverrides & { displayFont, bodyFont }>>

  // Property preferences — global biases (per-property rows live in
  // BrandDNAPropertyPreference).
  tierBias  String? // "luxury" | "mid_range" | "value"
  styleBias String[] // e.g. "honeymoon", "family", "adventure", "eco_luxury"

  // Free-text AI instructions
  aiInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertyPreferences BrandDNAPropertyPreference[]
  suggestions         BrandDNASuggestion[]
}

// Per-property entries (preferred or avoided), optionally scoped by location.

model BrandDNAPropertyPreference {
  id        String          @id @default(cuid())
  profileId String
  profile   BrandDNAProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  kind         String // "preferred" | "avoided"
  location     String?
  propertyName String
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([profileId, kind])
}

// Self-building: rows are generated from observed user behaviour. They are
// *suggestions only* and must never auto-apply.

model BrandDNASuggestion {
  id        String          @id @default(cuid())
  profileId String
  profile   BrandDNAProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  kind      String // "voice" | "property" | "visual"
  title     String
  rationale String?
  payload   Json? // applicable patch if the user accepts
  status    String  @default("pending") // pending | accepted | dismissed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, status])
}

// ─── Destination Visual Intelligence ────────────────────────────────────────
//
// Context-aware image library. Rows can be global (organizationId null) or
// per-organization. Selection priority is property images → org images →
// global images; filtering uses tags + category + animalType + experienceType.

model DestinationMediaAsset {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Location — free-form for now; upgrades to a FK when the Location model
  // lands in a later phase.
  locationId   String?
  locationName String?
  country      String?

  imageUrl     String
  thumbnailUrl String?
  width        Int?
  height       Int?

  provider         String? // "unsplash" | "pexels" | "upload" | "custom"
  photographerName String?
  photographerUrl  String?
  attributionText  String?

  tags           String[]
  category       String? // "wildlife" | "landscape" | "lodge" | "people" | "beach" | "city" | "airport"
  animalType     String? // "elephant" | "lion" | "giraffe" | ...
  experienceType String? // "game_drive" | "beach" | "arrival" | "hot_air_balloon" | ...

  priorityScore Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([locationName])
  @@index([category])
  @@index([animalType])
  @@index([experienceType])
}

// ─── Proposal ───────────────────────────────────────────────────────────────
//
// contentJson holds the entire Proposal object from src/lib/types.ts:
//   { id, metadata, operator, client, trip, theme, activeTier, visibleTiers,
//     sections, days, properties, pricing, inclusions, exclusions, practicalInfo }
//
// title and status are denormalised for queries (list proposals, filter drafts).

model Proposal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tenant scope. Nullable to survive the schema migration for any pre-org
  // rows, but every new proposal is created with this set; queries always
  // filter by organizationId so pre-org rows are invisible until backfilled.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title     String  @default("Untitled Proposal")
  status    String  @default("draft") // draft | sent | accepted
  isPublic  Boolean @default(false)
  shareSlug String? @unique

  // Human-readable tracking id, "PRO-{YYYY}-{NNNN}". Allocated on
  // create per-org per-year via ProposalCounter. Nullable so legacy
  // proposals stay valid; readers fall back to id.slice(-8) when this
  // is unset.
  trackingId String?

  contentJson Json // Full Proposal object — see src/lib/types.ts

  deposits             ProposalDeposit[]
  reservations         Reservation[]
  proposalReservations ProposalReservation[]
  events               ProposalEvent[]
  activitySummary      ProposalActivitySummary?

  // Optional link to the inbound Request this proposal was drafted for.
  // Nullable because legacy proposals + "blank canvas" drafts have no
  // request. When the operator creates a request-first flow, the proposal
  // is spawned with requestId set so the CRM can attribute the quote.
  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  // Denormalised client link for fast lookups ("all proposals for this
  // client"). Set alongside requestId when the flow starts from a request.
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments ProposalComment[]
  views    ProposalView[]

  @@unique([organizationId, trackingId])
  @@index([userId])
  @@index([organizationId])
  @@index([shareSlug])
  @@index([requestId])
  @@index([clientId])
}

// ─── Engagement tracking ───────────────────────────────────────────────────
//
// One row per anonymous viewer "session" (generated client-side on /p/[id]
// and stored in sessionStorage so reloads count as the same session). Each
// session accumulates an event log: open, section dwell, close.
//
// The operator wants three answers: did they open it, which sections did
// they linger on, and how long did they spend? This table answers all
// three without building a CRM.

model ProposalView {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // Anonymous viewer session id, generated client-side. Not tied to Clerk.
  sessionId String

  userAgent String?
  referrer  String?
  country   String?

  firstViewedAt DateTime @default(now())
  lastViewedAt  DateTime @default(now())
  viewCount     Int      @default(1)
  totalSeconds  Int      @default(0)

  events ProposalViewEvent[]

  @@unique([proposalId, sessionId])
  @@index([proposalId, lastViewedAt])
}

model ProposalViewEvent {
  id     String       @id @default(cuid())
  viewId String
  view   ProposalView @relation(fields: [viewId], references: [id], onDelete: Cascade)

  // "open" | "section" | "close"
  kind         String
  sectionId    String?
  dwellSeconds Int?

  createdAt DateTime @default(now())

  @@index([viewId, createdAt])
}

// ─── Proposal activity (org-level event log + precomputed summary) ────────
//
// ProposalView / ProposalViewEvent above are session-scoped (one row
// per anonymous viewer "session", events keyed to that view).
// ProposalEvent is a parallel, org-level append-only log keyed to the
// proposal directly so the dashboard's "what's hot today" answer can
// be computed without joining through the view sessions. Both tables
// coexist: ProposalView still drives the engagement KPIs in the
// dashboard summary, ProposalEvent + ProposalActivitySummary drive
// the new dealflow / activity surfaces.
//
// Event types written here: proposal_viewed, proposal_scrolled,
// itinerary_clicked, price_viewed, reservation_started,
// reservation_completed.

model ProposalEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // The Client (CRM "contact") attached to the proposal. Null when the
  // proposal has no client link (blank-canvas drafts, demo content).
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // The user attributed to this event when authenticated. Almost
  // always null because /p/[id] is anonymous; reserved for future
  // operator-side actions (e.g. "consultant marked viewed").
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  eventType String // see comment block above
  metadata  Json?  // free-form per-event payload (sectionId, sessionId, dwellSeconds, reservationId)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([proposalId, createdAt])
  @@index([clientId, createdAt])
  @@index([organizationId, eventType, createdAt])
}

// One row per proposal — precomputed counters + derived score / status
// / next-action so the dashboard endpoint can read fast without
// scanning the event log. Updated inside the same transaction that
// writes a ProposalEvent.

model ProposalActivitySummary {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  proposalId String   @unique
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  lastEventType String?
  lastEventAt   DateTime?

  // Counters / flags. Counters bump on every matching event;
  // boolean flags flip true the first time and stay true.
  viewedCount          Int     @default(0)
  scrolledCount        Int     @default(0)
  itineraryClicked     Boolean @default(false)
  priceViewed          Boolean @default(false)
  clickedReservation   Boolean @default(false) // mirrors reservation_started
  reservationCompleted Boolean @default(false)

  // Derived columns. status drives the dashboard groupings; readers
  // also re-derive "needs_followup" at read time using lastEventAt vs
  // now (so the column doesn't go stale waiting on a cron).
  engagementScore Int    @default(0)
  nextAction      String @default("Keep watching")
  status          String @default("watching") // watching | warm | hot | needs_followup | booked

  updatedAt DateTime @updatedAt

  @@index([organizationId, status, engagementScore])
  @@index([organizationId, lastEventAt])
}

// Per-org per-year counter for trackingId generation, mirroring the
// RequestCounter pattern. Format: "PRO-{year}-{value:04d}".

model ProposalCounter {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  year  Int
  value Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([organizationId, year])
}

// ─── Client interaction (lightweight) ───────────────────────────────────────
//
// Anonymous-friendly: a client visiting /p/[id] can leave a note without
// signing in (we capture name + email at the form level). Comments are
// proposal-scoped; the optional sectionId / dayId / propertyId let the UI
// anchor a comment to a specific moment without modelling a full thread.
//
// Status flips between "open" and "resolved" so the operator can clear
// out handled requests without losing history.

// ─── Reservations (supplier hold workflow) ─────────────────────────────────
//
// Lightweight layer for tracking the camp-hold request cycle operators
// do after a proposal is accepted: email the camp, wait for confirmation,
// chase if silent. No booking API integration — we just formalise the
// email + status dance so nothing slips.

model Reservation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  proposalId String?
  proposal   Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  // Freetext camp name at the time the hold was requested — so the
  // reservation survives if the operator later swaps the camp on the
  // proposal. propertyId links to the library when there's a match.
  campName   String
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  reservationsEmail String
  guestName         String
  startDate         DateTime
  endDate           DateTime
  adults            Int      @default(2)
  children          Int      @default(0)
  roomConfig        String? // "1 double + 1 twin" — free text
  notes             String?

  status      String    @default("pending") // "pending" | "sent" | "confirmed" | "declined" | "tentative" | "released"
  sentAt      DateTime?
  confirmedAt DateTime?
  heldUntil   DateTime?

  // GoHighLevel sync — populated when a supplier-followup workflow is
  // triggered or a supplier-side message is sent through GHL. Both
  // null until the integration runs.
  ghlMessageId     String?
  ghlWorkflowRunId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([proposalId])
}

// ─── Proposal client reservations ──────────────────────────────────────────
//
// Distinct from the supplier-side Reservation model above. This row is
// created when a client submits the "Make a Reservation" popup from
// inside a proposal share view (/p/[id]). It captures the contact
// details + arrival/departure window the client has confirmed at
// booking time (which may differ from the proposal's draft dates) and
// becomes the lead the consultant follows up to take payment.
//
// Routing:
//   - assignedUserId defaults to the consultant who created the
//     proposal (proposal.userId), so notification emails land with
//     the right person on the team. Owner / admins can re-assign.
//
// No payment fields here — those live on ProposalDeposit. We keep the
// reservation lightweight so it can be created without any external
// integration.

model ProposalReservation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // Client-supplied form fields
  firstName     String
  lastName      String
  email         String
  phone         String
  nationality   String?
  arrivalDate   DateTime
  departureDate DateTime
  travelers     String   @default("") // free text — "2 adults, 1 child age 7"
  notes         String?

  // Routing — defaults to the proposal's creator. Reassignable by the
  // owner / admin via the inbox UI.
  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  status    String   @default("new") // "new" | "contacted" | "confirmed" | "lost"

  // Outbound notification result captured at row creation. Mirrors the
  // ReservationDeliveryResult union from src/lib/notifications.ts:
  //   "sent"          → Resend accepted the message
  //   "skipped"       → mailer not configured (RESEND_API_KEY missing)
  //   "no-recipient"  → no operator email on file
  //   "failed"        → Resend returned a non-2xx response
  //   "timeout"       → 5s deadline elapsed before send completed
  // Surfaced as a small chip in the dashboard so the operator knows
  // whether to follow up by another channel.
  emailStatus String?

  // Anonymous client session that produced the reservation (matches
  // the sessionId used by the engagement tracker on /p/[id]). Lets us
  // tie a reservation back to the view session that produced it.
  sessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([proposalId])
  @@index([assignedUserId])
}

// ─── Proposal deposits ──────────────────────────────────────────────────────
//
// Payment records for the "Pay deposit" affordance on the public share
// view. One proposal can have many deposit attempts (failed card,
// retry etc.); the app shows the most-recent status to the operator.
// Paystack is the only processor wired for now.

model ProposalDeposit {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  payerName  String?
  payerEmail String

  // Amount in smallest currency unit (cents for USD, kobo for NGN, etc.)
  amountInCents Int
  currency      String @default("USD")

  status String @default("pending") // "pending" | "paid" | "failed" | "abandoned"

  processor         String    @default("paystack")
  paystackReference String    @unique
  paidAt            DateTime?

  // Digital acceptance — "I agree to terms" checkbox + typed name.
  // Not legally binding e-sig but gives the operator a clear audit
  // record of what the client saw at the moment of payment.
  termsAcceptedAt   DateTime?
  termsAcceptedText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proposalId, createdAt])
  @@index([status])
}

model ProposalComment {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // Optional anchors — set at most one to scope the comment to a part of
  // the proposal. Reserved for future inline-comment UI; for v1 the comment
  // form posts proposal-level and these stay null.
  sectionId  String?
  dayId      String?
  propertyId String?

  // Anonymous client identity, captured at submission time. Both optional —
  // some clients prefer to stay anonymous; we still accept the comment.
  authorName       String?
  authorEmail      String?
  // operator: when an operator replies the future inline-thread UI will
  // set this so the bubble renders on the right side.
  authorIsOperator Boolean @default(false)

  body   String
  status String @default("open") // open | resolved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proposalId, status])
  @@index([proposalId, createdAt])
}

// ─── Property System ────────────────────────────────────────────────────────
//
// The operator's curated library of camps, lodges, villas, etc. Properties
// are first-class so they can be browsed, filtered, reused across proposals,
// and (Phase 2) used to ground AI selection. When inserted into a proposal
// the relevant fields are *snapshotted* into the proposal's contentJson so
// the proposal stays stable if the source property is later edited.
//
// Locations are first-class too (not just strings on Property): canonical
// filter values, shared with Day records, and the join point for the
// destination-visual-intelligence layer.

model Location {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name    String
  country String?
  region  String? // optional sub-grouping (e.g. "Northern Tanzania")
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Basics
  name          String
  propertyClass String? // "camp" | "lodge" | "tented_camp" | "mobile_camp" | "boutique_hotel" | "villa" | "houseboat" | "treehouse" | "other"

  // Client-facing copy
  shortSummary     String?
  whatMakesSpecial String?
  whyWeChoose      String?

  // Amenities — chip list, free-form
  amenities String[]

  // Stay snapshot
  mealPlan        String? // "Full board" | "Half board" | "B&B" | "All-inclusive" | etc.
  suggestedNights Int?
  suitability     String[] // ["families", "honeymoon", "photography", ...]

  // Showcase facts — rendered in PropertyShowcaseSection's STATS sidebar
  checkInTime      String?
  checkOutTime     String?
  totalRooms       Int?
  spokenLanguages  String[]
  specialInterests String[]
  // Per-property visibility toggle for the "Fun Facts" block (rooms /
  // languages / interests). Default true so existing properties keep
  // their current rendering; operators flip it off when those facts
  // aren't a fit for a particular lodge.
  funFactsVisible  Boolean  @default(true)

  // Camp reservations email — used by the supplier-hold workflow
  // (Step 8). Operator enters once, re-used on every hold request.
  reservationsEmail String?

  // Internal — never rendered client-side
  internalNotes String?

  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images         PropertyImage[]
  tags           PropertyTagOnProperty[]
  customSections PropertyCustomSection[]
  rooms          PropertyRoom[]
  reservations   Reservation[]

  @@index([organizationId])
  @@index([organizationId, archived])
  @@index([organizationId, propertyClass])
  @@index([organizationId, locationId])
}

model PropertyRoom {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  name        String
  bedConfig   String?
  description String?
  imageUrls   String[]
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, order])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  url     String
  caption String?
  order   Int     @default(0)
  isCover Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([propertyId, order])
}

model PropertyTag {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime @default(now())

  properties PropertyTagOnProperty[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model PropertyTagOnProperty {
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tagId String
  tag   PropertyTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([propertyId, tagId])
  @@index([tagId])
}

model PropertyCustomSection {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  title   String
  body    String?
  visible Boolean @default(true)
  order   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, order])
}

// ─── CRM: Client ────────────────────────────────────────────────────────────
//
// A person (or traveller group) that has contacted the tour operator.
// Deduped by email within an organisation — the second request from the
// same email links to the same client record so the detail view can show
// "3 prior requests, 1 booked". Fields mirror the reference app's client
// card (email, names, salutation, country, phone, language).

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email             String
  firstName         String?
  lastName          String?
  salutation        String?
  phone             String?
  country           String? // ISO country code or free-text — display uses flagFor()
  origin            String? // "where they're flying from" — distinct from country of residence
  preferredLanguage String? // communication language: "English" | "German" | ...

  // Free-form tags & notes (internal only, never rendered to the client).
  tags          String[]
  internalNotes String?

  // GoHighLevel sync — populated when this client is mirrored to the
  // org's connected GHL workspace. Null until the first sync.
  ghlContactId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests  Request[]
  proposals Proposal[]
  messages  Message[]
  proposalEvents          ProposalEvent[]
  proposalActivitySummaries ProposalActivitySummary[]

  @@unique([organizationId, email])
  @@index([organizationId, lastName])
  @@index([organizationId])
  @@index([ghlContactId])
}

// ─── CRM: Lead source (per-org taxonomy) ───────────────────────────────────
//
// Operator-defined sources: SafariBookings, TripAdvisor, Website form,
// Referral, Trade show, Direct email, Unknown. Seeded with a default set
// on org creation and editable under Settings → Lead Sources. Requests
// reference these by name (denormalised) so the analytics view can slice
// conversion rate per source without a join.

model LeadSource {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  sortOrder Int     @default(0)
  archived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, archived])
}

// ─── CRM: Request (inbound inquiry) ────────────────────────────────────────
//
// The new top-level object — a client inquiry that flows through the
// pipeline: new → working → open → booked → completed | not_booked.
// A Request owns one or more Proposals (quotes) and an activity timeline.
//
// referenceNumber is the human-readable id the operator references in
// emails ("your request #2026-0042"). Generated per-org per-year via the
// RequestCounter table so two orgs can share the same number without
// collision.

model Request {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  referenceNumber String // e.g. "2026-0042"
  status          String @default("new") // new | working | open | booked | completed | not_booked

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  assignedToUserId String?
  assignedTo       User?   @relation("RequestAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  source       String? // denormalised LeadSource name
  sourceDetail String? // free text ("Referred by Kendra")

  // Time-to-first-response metrics. receivedAt is when the lead landed,
  // firstReplyAt fires on the first user-driven action (note, quote, or
  // status change off "new"). lastActivityAt is bumped by any mutation.
  receivedAt     DateTime  @default(now())
  firstReplyAt   DateTime?
  assignedAt     DateTime?
  lastActivityAt DateTime  @default(now())

  // Short form of the trip brief (dates, nights, destinations, travelers,
  // style, operator note). Full trip detail lives on the drafted Proposal.
  tripBrief Json?

  // Free-text note the operator enters when creating the request.
  originalMessage String?

  // GoHighLevel sync — populated when an opportunity is created in the
  // org's GHL pipeline. ghlStageId mirrors the current stage so we can
  // detect drift if it's moved manually inside GHL.
  ghlOpportunityId String?
  ghlStageId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposals Proposal[]
  notes     RequestNote[]
  tasks     RequestTask[]
  messages  Message[]

  @@unique([organizationId, referenceNumber])
  @@index([organizationId, status])
  @@index([organizationId, assignedToUserId])
  @@index([organizationId, receivedAt])
  @@index([clientId])
}

// Per-org per-year counter for referenceNumber generation. Each time a
// request is created, we upsert this row and increment. The formatted
// number is "{year}-{nextValue:04d}".

model RequestCounter {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  year  Int
  value Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([organizationId, year])
}

// ─── CRM: Request activity feed ────────────────────────────────────────────
//
// Mixed timeline — user-authored notes + system-generated events
// ("Status changed to Open", "Quote v2 sent", "Assigned to Lilian").
// Rendered as the right-hand rail of the request detail view.

// ─── CRM: Request tasks ────────────────────────────────────────────────────
//
// Small todos attached to a request. Mirrors the reference app's "Tasks"
// tab — things the operator remembers to do later ("follow up next
// Monday", "send flight options by Friday"). Due dates are optional; the
// dashboard "overdue" band will eventually include due-date task misses.

model RequestTask {
  id        String  @id @default(cuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  title  String
  notes  String?
  dueAt  DateTime?
  doneAt DateTime?

  // Not nullable — if the author is later removed from the org we still
  // want to know who created the task. Using the User FK keeps joins cheap.
  createdByUserId String?
  order           Int     @default(0)

  // ── Phase 5 — intelligence-driven follow-ups ────────────────────────
  // Task came from the priorities-dashboard "Add task" button. The
  // actionType matches NextActionType in dealScoring.ts and is the
  // dedup key — we only allow one open task per (requestId, actionType)
  // so re-clicking "Add task" returns the existing row.
  actionType    String? // "reply" | "send_proposal" | "draft_quote" | "nudge" | "ask_for_booking" | "follow_up" | "confirm_reservation" | "stay_in_touch" | "wait"
  // Priority level mirrors the priority card label at task-creation time.
  priorityLevel String? @default("normal") // "high" | "normal" | "low"
  // Reason from the scoring engine — why this action was suggested.
  // Surfaces in the task detail so the operator remembers why they
  // committed to it later.
  reason        String?
  // True when system-created (auto-fill / hot-deal cron); false when a
  // human typed the title themselves. Used to filter system noise out
  // of "what did I commit to" reports.
  auto          Boolean @default(false)

  // Outcome attribution — Phase 6.
  //   pending     — task open, or completed but the attribution
  //                 window hasn't elapsed yet
  //   converted   — task closed AND a booking landed for the same
  //                 request within ATTRIBUTION_WINDOW_DAYS
  //   no_response — task closed AND no booking landed in window
  // Set by:
  //   - real-time hook in PATCH /api/requests/[id] when status flips
  //     to "booked" (immediate "converted" attribution)
  //   - daily cron at /api/cron/attribute-outcomes (eventual
  //     "no_response" attribution after window elapses)
  taskOutcome     String    @default("pending")
  // When the linked Request was booked. Denormalised so the
  // performance API doesn't have to rejoin per task. Null for
  // tasks that never converted.
  bookedAt        DateTime?
  // First outbound message sent on this request between task
  // creation and task completion. Lets us prove "this follow-up
  // led to a reply" later. Null when no message was sent.
  linkedMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId, order])
  @@index([requestId, doneAt])
  @@index([requestId, actionType, doneAt])
}

model RequestNote {
  id        String  @id @default(cuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  authorUserId String?
  author       User?   @relation("RequestNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  kind String // "user" | "system"
  body String

  createdAt DateTime @default(now())

  @@index([requestId, createdAt])
}

// ─── Team presence (who's online, what they're doing) ──────────────────────
//
// One row per user — updated every ~30s by a client-side heartbeat.
// currentView encodes the "what" in a stable-enough-to-display string
// ("request:abc123", "studio", "library"). Admin's Team page polls this
// and renders a green/amber/grey dot plus a human-readable activity.
//
// Upgrade path: swap heartbeat + polling for Supabase Realtime presence
// channels once the team size makes polling wasteful.

model Presence {
  userId         String       @id
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  currentView   String? // e.g. "request:abc123", "studio", "library", "proposal:xyz"
  currentAction String? // short verb — "editing", "viewing", "drafting"
  lastActiveAt  DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([organizationId, lastActiveAt])
}

// ─── Activity log (auditable event stream) ─────────────────────────────────
//
// Append-only record of significant actions. Drives the admin's live
// activity feed and per-user timeline. Keeping it separate from Presence
// so presence stays small + fast to poll, while the log accumulates.

model ActivityEvent {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type       String // signin, signout, viewRequest, createRequest, createQuote,
  // sendQuote, assignRequest, changeStatus, postNote,
  // editProposal, archiveProperty, editBrandDNA
  targetType String? // "request" | "proposal" | "property" | "client" | "brand_dna"
  targetId   String?
  detail     Json? // structured context — e.g. { fromStatus: "new", toStatus: "working" }

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([organizationId, type, createdAt])
}

// ─── Messages (inbox + threaded comms) ─────────────────────────────────────
//
// Inbound and outbound messages. GHL is currently the only provider, but
// the schema is provider-agnostic — direct SMTP, Twilio, etc. could
// follow without a migration. Phase 1 stores the rows; Phase 4 wires
// the inbox UI.
//
// Either clientId or requestId may be null — system-channel messages
// (e.g. "GHL workflow triggered") have neither. Read state is org-level
// for now (a null `readAt` = unread for everyone in the workspace);
// per-user readstate is a future enhancement.

model Message {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  direction String // "inbound" | "outbound"
  channel   String // "email" | "sms" | "whatsapp" | "system"
  subject   String?
  body      String

  status String @default("draft") // "draft" | "sent" | "delivered" | "failed" | "received"

  // Provider linkage. Single GHL provider for now; structured to allow
  // a future multi-provider switch without a migration.
  provider          String? // "ghl"
  ghlMessageId      String? @unique
  ghlConversationId String?

  // Read state for the inbox unread badge. Null = unread; set when an
  // operator opens the message (or the request thread that contains it).
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, direction, readAt])
  @@index([clientId, createdAt])
  @@index([requestId, createdAt])
  @@index([ghlConversationId])
}

// ─── Integration log (provider-call audit trail) ──────────────────────────
//
// One row per GHL request (and any future provider). Drives the admin's
// "retry sync" affordance and gives a paper trail when a workflow
// silently fails. Append-only — never edit. Successful rows are kept
// for analytics; failed rows surface in the integrations panel.

model IntegrationLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider String // "ghl"
  action   String // "createContact" | "createOpportunity" | "moveOpportunity" | "triggerWorkflow:proposal_sent" | …

  // Optional reference to the local entity that triggered the call —
  // e.g. entityType="request", entityId=request.id. Lets us surface
  // "all GHL calls related to this request" in the admin view.
  entityType String?
  entityId   String?

  status          String // "success" | "failed" | "pending"
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?

  // Retry bookkeeping. attemptCount starts at 1; nextRetryAt is set on
  // a recoverable failure to schedule a retry, null otherwise.
  attemptCount Int       @default(1)
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([entityType, entityId])
  @@index([provider, status, nextRetryAt])
}

// ─── AISuggestion — log of operator-facing AI drafts ───────────────────────
//
// Every "draft for me" surface (follow-up generator, reservation summary,
// future hot-deal next-action LLM, etc.) writes one row here when the
// model returns. The operator's workflow is always draft → review →
// manual send, so this table tracks what was suggested and what they
// actually did with it (applied / dismissed / superseded).
//
// `kind`        — namespaced action key, e.g. "follow-up" / "reservation-summary".
// `targetType`  — the entity the suggestion is *about* ("proposal" / "reservation"
//                 / "request").
// `targetId`    — id of that entity. Not a foreign key on purpose — entities
//                 may be deleted while suggestion history is kept for review.
// `input`       — JSON payload the model saw (sliced context, signals).
// `output`      — generated text the operator sees.
// `status`      — "pending" (default), "applied", "dismissed".
// Cost / token usage stays in API logs — this row is for the operator
// audit trail, not Anthropic billing.

model AISuggestion {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  kind       String
  targetType String
  targetId   String

  input  Json?
  output String

  // Lifecycle. status reflects what the operator did with the draft;
  // outcome reflects the downstream conversion signal that came back.
  // Both default to "pending"/null and move forward over time as the
  // dashboard records sentAt → repliedAt → bookedAt.
  status    String    @default("pending") // "pending" | "applied" | "dismissed"
  appliedAt DateTime?

  // Send + outcome tracking. channel is the channel the operator chose
  // when dispatching ("whatsapp" | "email"); sentAt fires the moment
  // they hit "Send now" in the dashboard. repliedAt + bookedAt are
  // populated by the activity-event pipeline when an inbound reply or
  // a reservation_completed lands on the same proposal.
  channel    String?
  sentAt     DateTime?
  repliedAt  DateTime?
  bookedAt   DateTime?
  outcome    String?  // "sent" | "replied" | "booked" | "no-response"

  // Safe Auto-Send. autoSendScheduledFor is set when the operator
  // schedules an auto-send from a VERY_HOT deal card; the dashboard's
  // countdown reads from this column. autoSent flips to true once the
  // /auto-send route completes a real dispatch (Resend HTTP API). The
  // schedule cancels automatically when conditions change (operator
  // sends manually, status drops, client replies) — see
  // src/lib/dealMomentum.ts canAutoSend().
  autoSendScheduledFor DateTime?
  autoSent             Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, kind])
  @@index([targetType, targetId])
  @@index([targetType, targetId, kind, createdAt])
}
