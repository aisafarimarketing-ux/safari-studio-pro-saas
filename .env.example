# ── Database ──────────────────────────────────────────────────────────────────
# Supabase session pooler URL (IPv4-friendly):
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Supabase Storage (image uploads) ──────────────────────────────────────────
# The project URL (e.g. https://mxajhbjbugcenldideuc.supabase.co). Without
# these, uploads fall back to inline base64 in the proposal JSON (fine for
# dev but makes proposals huge + PDF export slow).
NEXT_PUBLIC_SUPABASE_URL=
# Service-role key (Supabase Dashboard → Project Settings → API →
# service_role). Server-side ONLY — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override the storage bucket name (default: "proposal-assets").
# SUPABASE_STORAGE_BUCKET=proposal-assets

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: override model (default claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Clerk auth ────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional: override Clerk redirect URLs (defaults work for most setups)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/proposals
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/select-organization

# Clerk Organizations must be enabled in the Clerk dashboard with personal
# accounts OFF. Every authenticated user must belong to an organization;
# middleware redirects to /select-organization otherwise.
